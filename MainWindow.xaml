<Window x:Class="InScreenApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="WinAnchor"
        Icon="WinAnchor.ico"
        Width="560"
        Height="640"
        MinWidth="520"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DataTemplate x:Key="PinnedWindowItemTemplate">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="32"
                        Height="32"
                        CornerRadius="6"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource AccentBorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="&#xE8A7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,8,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ProcessName}"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource ChromeButtonStyle}"
                        Width="32"
                        Height="32"
                        Content="&#xE712;"
                        ToolTip="Unpin this window"
                        Click="PinnedItemMore_Click" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource MicaBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="1"
                              Opacity="0.14"
                              Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="28"
                            Height="28"
                            CornerRadius="6"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0">
                        <Image Source="WinAnchor.ico"
                               Width="18"
                               Height="18"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="WinAnchor"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource ChromeButtonStyle}"
                                Content="&#xE921;"
                                ToolTip="Minimize"
                                Click="MinimizeButton_Click" />
                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseChromeButtonStyle}"
                                Content="&#xE8BB;"
                                ToolTip="Close — unpin all and exit"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16">
                <StackPanel>
                    <!-- Get started -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Get started"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <Button x:Name="PinNewWindowButton"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource PrimaryCtaButtonStyle}"
                                    Click="PinNewWindowButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Pin New Window"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Pinned windows -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Pinned windows"
                                           Style="{StaticResource SectionLabelStyle}"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="PinnedCountText"
                                           HorizontalAlignment="Right"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="0 pinned" />
                            </Grid>

                            <ListBox x:Name="PinnedWindowsList"
                                     ItemContainerStyle="{StaticResource PinnedListBoxItemStyle}"
                                     ItemTemplate="{StaticResource PinnedWindowItemTemplate}"
                                     MinHeight="72"
                                     MaxHeight="140"
                                     SelectionChanged="PinnedWindowsList_SelectionChanged" />
                        </StackPanel>
                    </Border>

                    <!-- Window position pad -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Window position"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Drag to move selected window"
                                       Margin="0,4,0,12"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}" />

                            <Border x:Name="PositionPadPanel"
                                    Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="False"
                                    Opacity="0.45">
                                <Grid MinHeight="168">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↖"
                                            Tag="NW"
                                            ToolTip="Move up-left"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↑"
                                            Tag="N"
                                            ToolTip="Move up"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↗"
                                            Tag="NE"
                                            ToolTip="Move up-right"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="1" Grid.Column="0"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="←"
                                            Tag="W"
                                            ToolTip="Move left"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource DirectionPadCenterButtonStyle}"
                                            Content="●"
                                            Tag="Center"
                                            ToolTip="Reset to default position"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="1" Grid.Column="2"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="→"
                                            Tag="E"
                                            ToolTip="Move right"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="2" Grid.Column="0"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↙"
                                            Tag="SW"
                                            ToolTip="Move down-left"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="2" Grid.Column="1"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↓"
                                            Tag="S"
                                            ToolTip="Move down"
                                            Click="PositionPadButton_Click" />
                                    <Button Grid.Row="2" Grid.Column="2"
                                            Style="{StaticResource DirectionPadButtonStyle}"
                                            Content="↘"
                                            Tag="SE"
                                            ToolTip="Move down-right"
                                            Click="PositionPadButton_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Window controls toolbar -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <UniformGrid Columns="3">
                            <Button x:Name="SmallerButton"
                                    Margin="0,0,4,0"
                                    Style="{StaticResource IconToolButtonStyle}"
                                    IsEnabled="False"
                                    Click="SmallerButton_Click">
                                <StackPanel>
                                    <TextBlock Text="&#xE71F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Smaller"
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LargerButton"
                                    Margin="2,0"
                                    Style="{StaticResource IconToolButtonStyle}"
                                    IsEnabled="False"
                                    Click="LargerButton_Click">
                                <StackPanel>
                                    <TextBlock Text="&#xE8A3;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Larger"
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="UnpinButton"
                                    Margin="4,0,0,0"
                                    Style="{StaticResource IconToolButtonStyle}"
                                    IsEnabled="False"
                                    Click="UnpinButton_Click">
                                <StackPanel>
                                    <TextBlock Text="&#xE785;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Unpin..."
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <!-- Status -->
                    <Border Padding="12,10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock x:Name="StatusText"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Ready" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
