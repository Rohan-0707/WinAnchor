<Window x:Class="InScreenApp.UnpinPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Unpin Windows"
        Icon="WinAnchor.ico"
        Width="420"
        Height="480"
        MinWidth="380"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource MicaBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="1"
                              Opacity="0.12"
                              Color="#000000" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Select windows to unpin"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Restore pinned windows to full screen"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource CloseChromeButtonStyle}"
                        Content="&#xE8BB;"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="CancelButton_Click" />
            </Grid>

            <!-- Hint -->
            <Border Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="10,8"
                    Background="{StaticResource AccentSoftBrush}"
                    BorderBrush="{StaticResource AccentBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Use checkboxes or Ctrl/Shift to select multiple windows." />
            </Border>

            <!-- Pinned list -->
            <Border Grid.Row="2"
                    Style="{StaticResource DialogCardStyle}">
                <ListBox x:Name="PinnedList"
                         ItemTemplate="{StaticResource UnpinWindowRowItemTemplate}"
                         SelectionMode="Extended" />
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="0,16,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Margin="0,0,8,0"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Click="CancelButton_Click" />
                    <Button x:Name="UnpinSelectedButton"
                            Content="Unpin Selected"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            IsEnabled="False"
                            Click="UnpinSelectedButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
